{
  "share": "auto",
  "$schema": "https://tribunus.dev/config.json",
  "default_agent": "general-man-agent",
  "provider": {},
  "permission": {
    "*": "deny",
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*": "allow"
    },
    "doom_loop": "deny",
    "question": "deny",
    "external_directory": "deny"
  },
  "mcp": {},
  "agent": {
    "general-man-agent": {
