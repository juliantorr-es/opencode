{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rig.relay.reporting_honesty_audit.v1",
  "title": "Reporting Honesty Audit",
  "description": "Structured audit artifact that flags overclaim language in reporting artifacts — claims that exceed their supporting evidence.",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "rig.relay.reporting_honesty_audit.v1"
    },
    "audit_id": {
      "type": "string",
      "description": "Unique audit identifier"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "lane_id": {
      "type": "string"
    },
    "methodology": {
      "type": "string",
      "description": "Detection methodology including grep patterns, scan criteria, and reproducibility notes"
    },
    "severity_rubric": {
      "type": "object",
      "description": "Clear definitions for each severity level",
      "properties": {
        "high": {
          "type": "string",
          "description": "Evidence actively contradicts the claim. Examples: claim says 'zero errors' but data shows 280 errors; claim says 'production-proven' but no deployment exists."
        },
        "medium": {
          "type": "string",
          "description": "Evidence is missing, insufficient, or internally inconsistent. Examples: empty verification section, bare aggregation claims without evidence links, concurrency claims without stress testing."
        },
        "low": {
          "type": "string",
          "description": "Claim is technically true but framing minimizes context or is misleading in aggregate. Examples: 'zero new errors' buries 383 pre-existing errors; internal field naming contradictions."
        }
      },
      "required": ["high", "medium", "low"]
    },
    "detection_criteria": {
      "type": "array",
      "description": "Explicit patterns used to detect overclaims",
      "items": {
        "type": "string"
      }
    },
    "maturity_level_taxonomy": {
      "type": "object",
      "description": "Standardized maturity levels for classifying artifact claims",
      "additionalProperties": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact_path": {
            "type": "string",
            "description": "Path to the artifact containing the overclaim"
          },
          "observed_claim": {
            "type": "string",
            "description": "The specific claim or language being flagged"
          },
          "evidence_gap": {
            "type": "string",
            "description": "Why the claim exceeds its supporting evidence"
          },
          "suggested_maturity_level": {
            "type": "string",
            "description": "The highest maturity level honestly supported by the evidence"
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "pattern_type": {
            "type": "string",
            "description": "Classification of overclaim pattern"
          }
        },
        "required": ["artifact_path", "observed_claim", "evidence_gap", "suggested_maturity_level", "severity"]
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_artifacts_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "total_findings": {
          "type": "integer",
          "minimum": 0
        },
        "high_severity": {
          "type": "integer",
          "minimum": 0
        },
        "medium_severity": {
          "type": "integer",
          "minimum": 0
        },
        "low_severity": {
          "type": "integer",
          "minimum": 0
        },
        "worst_offenders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_path": { "type": "string" },
              "reason": { "type": "string" },
              "overclaim_type": { "type": "string" }
            },
            "required": ["artifact_path", "reason", "overclaim_type"]
          }
        },
        "recommended_rewrite_priority": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rank": { "type": "integer" },
              "artifact": { "type": "string" },
              "action": { "type": "string" },
              "effort": { "type": "string" },
              "impact": { "type": "string" }
            },
            "required": ["rank", "artifact", "action", "effort", "impact"]
          }
        },
        "positive_examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact": { "type": "string" },
              "reason": { "type": "string" }
            },
            "required": ["artifact", "reason"]
          }
        },
        "patterns_summary": {
          "type": "object"
        }
      },
      "required": ["total_artifacts_scanned", "total_findings", "high_severity", "medium_severity", "low_severity"]
    }
  },
  "required": ["schema", "audit_id", "generated_at", "findings", "summary"]
}
