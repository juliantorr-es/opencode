{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tribunus.dev/schemas/prepublication_review_cycle.v1",
  "title": "Prepublication Review Cycle",
  "description": "Schema for prepublication review cycles that capture review rounds, findings, builder responses, and the admission verdict.",
  "type": "object",
  "$defs": {
    "NormalizedError": {
      "$ref": "https://opencode.ai/schemas/defs.json#/$defs/NormalizedError"
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of this schema"
    },
    "reviewRound": {
      "type": "integer",
      "minimum": 1,
      "description": "Review round number (1-based)"
    },
    "candidateBoundary": {
      "type": "string",
      "description": "The boundary of the candidate under review"
    },
    "candidateSha": {
      "type": "string",
      "description": "SHA of the candidate commit being reviewed"
    },
    "findings": {
      "type": "array",
      "description": "Findings identified during this review round",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Finding identifier" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "description": { "type": "string", "description": "Finding description" },
          "evidence": { "type": "string", "description": "Supporting evidence" },
          "builderResponse": { "type": "string", "description": "Builder's response to the finding" }
        },
        "required": ["id", "severity", "description"]
      }
    },
    "builderResponses": {
      "type": "array",
      "description": "Builder responses to findings",
      "items": {
        "type": "object",
        "properties": {
          "findingId": { "type": "string", "description": "ID of the finding being responded to" },
          "response": { "type": "string", "description": "Builder's response" },
          "actionTaken": { "type": "string", "description": "Action taken by the builder" }
        },
        "required": ["findingId", "response"]
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["admitted", "rejected", "revision_required"],
      "description": "Verdict for this review round"
    },
    "admittedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the candidate was admitted"
    },
    "rejectedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the candidate was rejected"
    }
  },
  "required": ["schemaVersion", "reviewRound", "candidateBoundary", "findings", "verdict"]
}
