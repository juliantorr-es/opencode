{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tribunus.dev/schemas/migration_caller_inventory.v1",
  "title": "Database Migration Caller Inventory",
  "description": "Inventory of all files importing Database.* functions from @/storage/db, classified by call site usage patterns for migration planning.",
  "type": "object",
  "$defs": {
    "NormalizedError": {
      "$ref": "https://opencode.ai/schemas/defs.json#/$defs/NormalizedError"
    }
  },
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["rig.relay.migration_caller_inventory.v1"],
      "description": "Schema identifier"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "total_files": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of files importing from Database"
    },
    "total_call_sites": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of Database.* call sites across all files"
    },
    "files": {
      "type": "array",
      "description": "Per-file inventory entries",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File path" },
          "call_sites": { "type": "integer", "description": "Number of call sites in this file" },
          "effectSyncWraps": { "type": "integer", "description": "Number of Effect.sync wraps" },
          "effectTryWraps": { "type": "integer", "description": "Number of Effect.try wraps" },
          "rawCalls": { "type": "integer", "description": "Number of raw calls" },
          "getCalls": { "type": "integer", "description": "Number of get calls" },
          "runCalls": { "type": "integer", "description": "Number of run calls" }
        },
        "required": ["path", "call_sites"]
      }
    },
    "patterns": {
      "type": "object",
      "properties": {
        "total_Effect_sync_wraps": { "type": "integer", "description": "Total Effect.sync wraps across all files" },
        "total_Effect_try_wraps": { "type": "integer", "description": "Total Effect.try wraps across all files" },
        "total_raw_calls": { "type": "integer", "description": "Total raw calls across all files" },
        "total_get_calls": { "type": "integer", "description": "Total get calls across all files" },
        "total_run_calls": { "type": "integer", "description": "Total run calls across all files" }
      },
      "required": [
        "total_Effect_sync_wraps",
        "total_Effect_try_wraps",
        "total_raw_calls",
        "total_get_calls",
        "total_run_calls"
      ]
    }
  },
  "required": ["schema", "generated_at", "total_files", "total_call_sites", "files", "patterns"]
}
