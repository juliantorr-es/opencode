      "file": "packages/opencode/src/campaign/state-machine.ts:419-483",
      "signature": "export function reduceCampaignState(previous: CampaignState, machineSpec: AgentStateMachineSpec, newEvents: readonly RuntimeEvent[]): CampaignState",
      "algorithm": [
        "1. Clone retryBudgets into working map",
        "2. Concatenate all events (previous.events + newEvents) into allEvents",
        "3. Start with currentState from previous state",
        "4. For each event in allEvents (in order):",
        "   a. Look up AgentStateSpec for currentState",
        "   b. Filter transitions where evaluatePredicate() returns true",
        "   c. Sort by priority (lower number = higher priority, default 100)",
        "   d. Take first matching transition (break after found)",
        "   e. If transition found: update currentState, record StateTransition, exec entry actions",
        "5. Return new CampaignState with updated currentState, stateHistory, transitionCount, events"
      ]
