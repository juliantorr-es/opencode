      "steps": ["propose-plan", "revise-plan / comment-plan / review-criticism", "plan (PlanExitTool)"],
      "data_flow": "Plan proposal → Revisions → Exit to execution"
    },
    {
      "name": "Roadmap lifecycle",
      "description": "Full roadmap CRUD across named phases.",
      "steps": ["roadmap-init", "roadmap-next → roadmap-progress → roadmap-deprecate → roadmap-prioritize"],
      "data_flow": "Phase artifacts → Roadmap items → Status transitions"
    },
    {
      "name": "Failure recording pipeline",
      "description": "Tool failures are collected, inspected, and fed back into context.",
