    {
      "name": "Delegate → Coordination pipeline",
      "description": "Delegation creates coordination claims for multi-agent orchestration.",
      "steps": ["prepare-delegation (prep manifest)", "delegate (spawn + claim lane)", "coordination (read claims, manage fan-out)"],
      "data_flow": "Delegation manifest → Coordination claim → Lane tracking"
    },
    {
      "name": "Checkpoint → Publication pipeline",
      "description": "Agent creates checkpoints, then publishes them through review gates.",
      "steps": ["prepare_checkpoint", "checkpoint", "publish_checkpoint", "generate_published_checkpoint_report"],
      "data_flow": "Prepared data → Checkpoint record → Published record → Report"
