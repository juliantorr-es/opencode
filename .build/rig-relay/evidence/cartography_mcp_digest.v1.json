    "in_session_tools_ts": true,
    "state_mutation_pattern": "Mutable objects (not Ref) via InstanceState.get → direct mutation of s.clients/s.status/s.defs/s.config",
    "concurrency_pattern": "Semaphore per server (withServerLock) — Sequence of 1 — used for createAndStore and disconnect",
    "layer_pattern": "Layer.effect for construction, layer.pipe(Layer.provide(...)) for defaultLayer composition",
    "service_pattern": "Context.Service + serviceUse for dependency injection"
  }
}
