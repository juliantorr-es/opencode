    "eventMappingRules": {
      "type": "object",
      "description": "Rules governing how stage-substrate mapping events are recorded and validated.",
      "required": [
        "eventSchema",
        "fallbackRules",
        "versioningRules"
      ],
      "properties": {
        "eventSchema": {
          "$anchor": "event-schema",
          "type": "object",
          "description": "Schema for a single stage-substrate mapping event.",
          "required": [
            "stage_id",
            "substrate_id",
            "backend"
          ],
          "properties": {
            "stage_id": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "description": "Numeric identifier of the pipeline stage. MUST reference a valid stage ID defined in the 'stages' object. Values 1-42 are defined in v1; higher values are user-defined for custom/extension stages."
            },
            "substrate_id": {
              "type": "integer",
              "minimum": 0,
              "maximum": 65535,
              "description": "Numeric identifier of the execution substrate. MUST reference a valid substrate ID defined in the 'substrates' object. Values 0-10 are defined in v1."
            },
            "layer_index": {
              "type": "integer",
              "minimum": 0,
              "description": "Index of the transformer layer this event applies to. 0-based. Omitted or null for non-layer-specific stages (e.g. worker_launch, session_creation)."
            },
            "attention_kind": {
              "type": "string",
              "description": "Kind of attention mechanism for attention-related stages. Values: 'mha' (multi-head), 'mqa' (multi-query), 'gqa' (grouped-query), 'mla' (multi-head latent). Omitted for non-attention stages.",
              "enum": ["mha", "mqa", "gqa", "mla"]
            },
            "graph_region_id": {
              "type": "string",
              "description": "Identifier for the model graph region or subgraph this event belongs to. Enables hierarchical tracing across model subcomponents."
            },
            "backend": {
              "type": "string",
              "minLength": 1,
              "description": "Canonical backend name (e.g. 'mlx', 'tribunus-metal', 'coreml', 'accelerate', 'cpu'). Matches substrate by convention but recorded as a string for forward compatibility."
            },
            "kernel_id": {
              "type": "string",
              "description": "Specific kernel or shader function name responsible for computation (e.g. 'metal::attention_kernel_v1', 'mlx::scaled_dot_product_attention'). Omitted for substrate-managed stages without kernel visibility."
            }
          },
          "additionalProperties": false
        },
        "fallbackRules": {
          "type": "object",
          "description": "Rules for recording fallback events when a stage fails on its primary substrate and retries on an alternative.",
          "required": ["recordFallbackAsDistinctEvent", "fallbackFields"],
          "properties": {
            "recordFallbackAsDistinctEvent": {
              "type": "boolean",
              "const": true,
              "description": "Fallback MUST be recorded as a separate distinct event, never merged or implied."
            },
            "fallbackFields": {
              "type": "object",
              "required": ["stage_id", "primary_substrate_id", "fallback_substrate_id", "fallback_reason"],
              "properties": {
                "stage_id": {
                  "type": "integer",
                  "description": "The stage that fell back"
                },
                "primary_substrate_id": {
                  "type": "integer",
                  "description": "The originally targeted substrate"
                },
                "fallback_substrate_id": {
                  "type": "integer",
                  "description": "The substrate the stage actually ran on"
                },
                "fallback_reason": {
                  "type": "string",
                  "description": "Reason for the fallback (e.g. 'kernel_not_found', 'device_memory_pressure', 'substrate_not_available', 'timeout')"
                }
              },
              "additionalProperties": false
            },
            "eventPayload": {
              "type": "object",
              "description": "A fallback event carries all standard event fields plus the fallback-specific fields. Both the primary and fallback events are recorded.",
              "allOf": [
                { "$ref": "#/$defs/stageEvent" },
                {
                  "type": "object",
                  "required": ["primary_substrate_id", "fallback_reason"],
                  "properties": {
                    "primary_substrate_id": { "type": "integer" },
                    "fallback_reason": { "type": "string" }
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "versioningRules": {
          "type": "object",
          "description": "Rules governing schema and taxonomy version evolution.",
          "required": ["backwardCompatibility", "stageImmutability", "substrateImmutability", "deprecationRule"],
          "properties": {
            "backwardCompatibility": {
              "type": "string",
              "const": "Existing stage and substrate IDs MUST never be reassigned, repurposed, or removed. New IDs may be added with strictly increasing values.",
              "description": "Backward compatibility guarantee for the taxonomy."
            },
            "stageImmutability": {
              "type": "string",
              "const": "Once assigned, a stage ID and its name are permanent. The semantic meaning of a stage MUST NOT change. Clarifying descriptions may be amended.",
              "description": "Immutability contract for stage definitions."
            },
            "substrateImmutability": {
              "type": "string",
              "const": "Once assigned, a substrate ID and its name are permanent. A substrate's general capability domain MUST NOT change, though implementation details may evolve.",
              "description": "Immutability contract for substrate definitions."
            },
            "deprecationRule": {
              "type": "string",
              "const": "If a stage or substrate becomes obsolete, it MUST NOT be reused. The definition is marked deprecated (removed from the enum of recommended IDs) but the ID and definition remain in the schema for historical traceability.",
              "description": "Deprecation policy for obsolete IDs."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "stageEvent": {
      "$anchor": "stage-event",
      "type": "object",
      "description": "A complete stage-substrate mapping event combining stage identification, substrate identification, and optional context fields.",
      "required": [
        "stage_id",
        "substrate_id",
        "backend"
      ],
      "properties": {
        "stage_id": { "type": "integer", "minimum": 1 },
        "substrate_id": { "type": "integer", "minimum": 0 },
        "layer_index": { "type": "integer", "minimum": 0 },
        "attention_kind": { "type": "string", "enum": ["mha", "mqa", "gqa", "mla"] },
        "graph_region_id": { "type": "string" },
        "backend": { "type": "string", "minLength": 1 },
        "kernel_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "fallbackEvent": {
      "$anchor": "fallback-event",
      "type": "object",
      "description": "A fallback event: all stage event fields plus fallback-specific fields.",
      "allOf": [
        { "$ref": "#/$defs/stageEvent" },
        {
          "type": "object",
          "required": ["primary_substrate_id", "fallback_reason"],
          "properties": {
            "primary_substrate_id": { "type": "integer", "minimum": 0, "description": "The originally targeted substrate ID" },
            "fallback_reason": { "type": "string", "minLength": 1, "description": "Human-readable reason for the fallback" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
