        "coreml_gpu": {
          "$anchor": "substrate-coreml-gpu",
          "type": "object",
          "required": ["id", "name", "description"],
          "properties": {
            "id": { "type": "integer", "const": 7 },
            "name": { "type": "string", "const": "coreml_gpu" },
            "description": { "type": "string", "const": "Apple Core ML execution on GPU via the Core ML framework's Metal backend." }
