{
  "$schema": "https://tribunus.dev/tui.json",
  "plugin": [
    [
      "./plugins/orchestration-tui.tsx",
      {
        "enabled": true,
        "label": "orchestration",
        "keybinds": {
          "orchestration.fleet.refresh": "ctrl+shift+r",
          "orchestration.fleet.summary": "ctrl+shift+s"
        }
      }
    ],
    [
      "./plugins/fleet-tui.tsx",
      {
        "enabled": true,
        "label": "orchestration",
        "keybinds": {
          "fleet.toggle": "ctrl+shift+f",
          "fleet.refresh": "ctrl+r"
        }
      }
    ],
    [
      "./plugins/tui-smoke.tsx",
      {
        "enabled": false,
        "label": "workspace",
        "keybinds": {
          "smoke_modal": "ctrl+alt+m",
          "smoke_screen": "ctrl+alt+o",
          "smoke_screen_home": "escape,ctrl+shift+h",
          "smoke_screen_modal": "ctrl+alt+m",
          "smoke_dialog_close": "escape,q"
        }
      }
    ]
  ]
}
