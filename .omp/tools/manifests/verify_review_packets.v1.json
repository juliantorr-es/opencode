{
  "schema": "omp.tool.manifest.v1",
  "tool_id": "verify_review_packets",
  "version": "1.0.0",
  "title": "Verify Review Packets",
  "description": "Verifies the handed-off source-review and Gemini IR ZIPs contain the source graph adapter, Oxc contribution counters, resolved edges, and review finding gate evidence.",
  "authority": {
    "risk_level": "read_only",
    "side_effects": "none",
    "requires_approval": false,
    "requires_hash_precondition": false,
    "allowed_roots": [
      "."
    ],
    "denied_patterns": [
      ".git/",
      "node_modules/",
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ],
    "max_files_touched": 0
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "source_zip_path": {
        "type": "string"
      },
      "ir_zip_path": {
        "type": "string"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "source_zip_sha256": {
        "type": "string"
      },
      "ir_zip_sha256": {
        "type": "string"
      },
      "source_zip_files": {
        "type": "number"
      },
      "source_graph": {
        "type": "object"
      }
    }
  },
  "provider_exports": {
    "mistral_function_calling": true,
    "openai_tools": true,
    "anthropic_tools": true,
    "mcp": true
  }
}
