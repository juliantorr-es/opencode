{
  "schema": "omp.tool.manifest.v1",
  "tool_id": "semantic_review_packet_export",
  "version": "1.0.0",
  "title": "Semantic Review Packet Export",
  "description": "Exports the semantic v1 review packet ZIP for Gemini-style code review.",
  "authority": {
    "risk_level": "write_medium",
    "side_effects": "filesystem_write",
    "requires_approval": false,
    "requires_hash_precondition": false,
    "allowed_roots": [
      "."
    ],
    "denied_patterns": [
      ".git/",
      "node_modules/",
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ],
    "max_files_touched": 5
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "output_path": {
        "type": "string"
      },
      "force": {
        "type": "boolean",
        "default": true,
        "description": "Rebuild the semantic packet instead of reusing an existing ZIP. Defaults to true for agent-facing handoffs."
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "zip_path": {
        "type": "string"
      },
      "zip_sha256": {
        "type": "string"
      },
      "warnings": {
        "type": "array"
      }
    }
  },
  "provider_exports": {
    "mistral_function_calling": true,
    "openai_tools": true,
    "anthropic_tools": true,
    "mcp": true
  }
}
